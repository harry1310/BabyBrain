@page
@using BabyBrain.Scrapers.Domain
@model IndexModel
@{
    ViewData["Title"] = "Find baby & toddler events";
    var ranges = new[] { ("today", "Today"), ("tomorrow", "Tomorrow"), ("week", "This week"), ("nextweek", "Next week"), ("custom", "Pick a date") };
    var radii = new[] { ("", "Any distance"), ("0.5", "½ mile"), ("1", "1 mile"), ("2", "2 miles"), ("3", "3 miles") };
    var currentRadius = Model.Filter.Radius?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
    var inv = System.Globalization.CultureInfo.InvariantCulture;
    var hasOriginCoords = Model.Filter.OriginLat is not null && Model.Filter.OriginLng is not null;
}

<h1 class="mb-4">What's on for little ones</h1>

<form method="get" class="card p-3 mb-4 bg-light">
    <div class="mb-3">
        <label class="form-label fw-semibold mb-2">When?</label>
        <div class="d-flex flex-wrap gap-2" role="radiogroup">
            @foreach (var (key, label) in ranges)
            {
                var checkedAttr = Model.Filter.Range == key ? "checked" : null;
                <input type="radio" class="btn-check" name="range" id="range-@key" value="@key" @checkedAttr
                       onchange="document.getElementById('customDateRow').classList.toggle('d-none', this.value !== 'custom')" />
                <label class="btn btn-outline-primary" for="range-@key">@label</label>
            }
        </div>
    </div>

    <div id="customDateRow" class="mb-3 @(Model.Filter.Range == "custom" ? "" : "d-none")">
        <label for="date" class="form-label fw-semibold">Date</label>
        <input type="date" id="date" name="date"
               value="@(Model.Filter.SpecificDate?.ToString("yyyy-MM-dd"))"
               class="form-control" style="max-width:14rem" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Distance from you</label>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <select name="radius" id="radius" class="form-select" style="max-width:11rem">
                @foreach (var (val, label) in radii)
                {
                    <option value="@val" selected="@(val == currentRadius ? "selected" : null)">@label</option>
                }
            </select>
            <input type="text" name="originPostcode" id="originPostcode"
                   value="@(hasOriginCoords ? "Current location" : Model.Filter.OriginPostcode)"
                   readonly="@(hasOriginCoords ? "readonly" : null)"
                   maxlength="32" class="form-control" placeholder="Your postcode" style="max-width:11rem"
                   autocomplete="postal-code" />
            <button type="button" id="useLocationBtn" class="btn btn-outline-secondary">📍 Use my location</button>
        </div>
        <div class="form-text">Pick a distance, then enter your postcode (or use your location) and press Search to only see events near you.</div>
        <div id="locationMsg" class="form-text text-primary"></div>
        @* Browser geolocation drops its coordinates here; typing a postcode clears them. *@
        <input type="hidden" name="originLat" id="originLat" value="@(Model.Filter.OriginLat?.ToString(inv))" />
        <input type="hidden" name="originLng" id="originLng" value="@(Model.Filter.OriginLng?.ToString(inv))" />
    </div>

    <div class="row g-3 align-items-end">
        <div class="col-md-6">
            <label for="ageMonths" class="form-label fw-semibold">How old is your child? <span class="text-muted">(months)</span></label>
            <input type="number" min="0" max="60" id="ageMonths" name="ageMonths" value="@Model.Filter.AgeMonths"
                   class="form-control" placeholder="e.g. 9" style="max-width:10rem" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </div>
</form>

<script>
(function () {
    // "Use my location" captures coordinates and shows "Current location" in
    // the postcode box, but does NOT search — the visitor presses Search like
    // every other filter. Clicking (or typing in) the box drops the captured
    // location so a postcode can be entered instead.
    var LOCATION_LABEL = 'Current location';
    var btn = document.getElementById('useLocationBtn');
    var latEl = document.getElementById('originLat');
    var lngEl = document.getElementById('originLng');
    var pcEl = document.getElementById('originPostcode');
    var msgEl = document.getElementById('locationMsg');
    var form = btn ? btn.form : null;
    if (!btn || !latEl || !lngEl || !pcEl || !form) return;

    function enterPostcodeMode() {
        latEl.value = '';
        lngEl.value = '';
        pcEl.value = '';
        pcEl.readOnly = false;
        if (msgEl) msgEl.textContent = '';
    }

    btn.addEventListener('click', function () {
        if (!navigator.geolocation) {
            if (msgEl) msgEl.textContent = "This browser can't share your location — type a postcode instead.";
            return;
        }
        if (msgEl) msgEl.textContent = 'Getting your location…';
        btn.disabled = true;
        navigator.geolocation.getCurrentPosition(
            function (pos) {
                btn.disabled = false;
                latEl.value = pos.coords.latitude;
                lngEl.value = pos.coords.longitude;
                // Show it in the box, but wait for Search — don't auto-submit.
                pcEl.value = LOCATION_LABEL;
                pcEl.readOnly = true;
                if (msgEl) msgEl.textContent = 'Got your location — press Search to use it.';
            },
            function (err) {
                btn.disabled = false;
                if (msgEl) {
                    msgEl.textContent = (err && err.code === 1)
                        ? 'Location permission denied — type a postcode instead.'
                        : "Couldn't get your location — type a postcode instead.";
                }
            },
            { timeout: 10000, maximumAge: 300000 }
        );
    });

    // Clicking the box while it shows "Current location" clears it for typing.
    pcEl.addEventListener('mousedown', function () {
        if (pcEl.readOnly) enterPostcodeMode();
    });
    // Same for a keyboard user — any key except Tab starts a fresh postcode.
    pcEl.addEventListener('keydown', function (ev) {
        if (pcEl.readOnly && ev.key !== 'Tab') enterPostcodeMode();
    });
    // Typing a postcode supersedes any captured coordinates.
    pcEl.addEventListener('input', function () {
        latEl.value = '';
        lngEl.value = '';
    });
    // Coordinates carry the location — don't also submit the label as a postcode.
    form.addEventListener('submit', function () {
        if (latEl.value && lngEl.value) pcEl.value = '';
    });
})();
</script>

@if (!string.IsNullOrEmpty(Model.DistanceNote))
{
    <div class="alert alert-info py-2 small">@Model.DistanceNote</div>
}

@if (Model.Results.Count == 0)
{
    <p class="text-muted">No events match those filters. If the database is empty, try
        <a asp-page="/Admin">Run a scrape</a>.</p>
}
else
{
    var mapPoints = Model.Results
        .Where(r => !string.IsNullOrEmpty(r.Postcode))
        .Select(r => new { r, key = BabyBrain.Web.Data.Geocode.Normalise(r.Postcode!) })
        .Where(x => Model.PostcodeCoords.ContainsKey(x.key))
        .Select(x => new
        {
            lat = Model.PostcodeCoords[x.key].Lat,
            lng = Model.PostcodeCoords[x.key].Lng,
            name = x.r.SessionName,
            venue = x.r.VenueName,
            date = x.r.Date.ToString("ddd d MMM"),
            time = x.r.StartTime.ToString("HH:mm"),
            url = x.r.SourceUrl,
            color = Categories.Color(x.r.Category),
            category = Categories.Label(x.r.Category),
            category_id = x.r.Category,
            postcode = x.r.Postcode,
            event_key = x.r.ExternalKey,
        })
        .ToList();
    var mapJson = System.Text.Json.JsonSerializer.Serialize(mapPoints);

    var legendCategories = Model.Results
        .Select(r => r.Category)
        .Distinct()
        .OrderBy(c => c)
        .ToList();

    <p class="text-muted" id="bb-result-count" data-total="@Model.Results.Count">@Model.Results.Count event@(Model.Results.Count == 1 ? "" : "s") found.</p>

    @if (legendCategories.Count > 0)
    {
        <div class="d-flex flex-wrap gap-3 align-items-center mb-3 small text-muted">
            <span class="fw-semibold text-body">Categories:</span>
            @foreach (var cat in legendCategories)
            {
                <button type="button" class="bb-cat-toggle d-inline-flex align-items-center gap-1 border-0 bg-transparent p-0"
                        data-category="@cat" title="Click to hide @Categories.Label(cat) events">
                    <span class="bb-cat-dot" style="display:inline-block; width:.7rem; height:.7rem; border-radius:50%; background:@Categories.Color(cat); border:1px solid rgba(0,0,0,.15);"></span>
                    <span class="bb-cat-label">@Categories.Label(cat)</span>
                </button>
            }
        </div>
        <style>
            .bb-cat-toggle { cursor: pointer; color: inherit; }
            .bb-cat-toggle:hover .bb-cat-label { text-decoration: underline; }
            .bb-cat-toggle.bb-cat-excluded .bb-cat-label { text-decoration: line-through; }
            .bb-cat-toggle.bb-cat-excluded { opacity: .55; }
            .bb-cat-toggle.bb-cat-excluded:hover .bb-cat-label { text-decoration: line-through; }
        </style>
        <script>
            (function () {
                var excluded = new Set();
                var countEl = document.getElementById('bb-result-count');
                var total = countEl ? parseInt(countEl.getAttribute('data-total'), 10) || 0 : 0;

                function plural(n) { return n === 1 ? '' : 's'; }
                function applyExclusions() {
                    var shown = 0;
                    document.querySelectorAll('.event-card').forEach(function (c) {
                        var cat = c.getAttribute('data-category') || '';
                        var hide = excluded.has(cat);
                        c.style.display = hide ? 'none' : '';
                        if (!hide) shown++;
                    });
                    if (countEl) {
                        countEl.textContent = excluded.size === 0
                            ? total + ' event' + plural(total) + ' found.'
                            : shown + ' of ' + total + ' event' + plural(total) + ' shown.';
                    }
                    if (window.bbMapApi) window.bbMapApi.setExcluded(excluded);
                }

                document.body.addEventListener('click', function (ev) {
                    var btn = ev.target.closest('.bb-cat-toggle');
                    if (!btn) return;
                    var cat = btn.getAttribute('data-category');
                    if (!cat) return;
                    if (excluded.has(cat)) {
                        excluded.delete(cat);
                        btn.classList.remove('bb-cat-excluded');
                        btn.title = 'Click to hide ' + (btn.querySelector('.bb-cat-label')?.textContent || '') + ' events';
                    } else {
                        excluded.add(cat);
                        btn.classList.add('bb-cat-excluded');
                        btn.title = 'Click to show ' + (btn.querySelector('.bb-cat-label')?.textContent || '') + ' events';
                    }
                    applyExclusions();
                });
            })();
        </script>
    }

    @if (mapPoints.Count > 0)
    {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
              integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <style>
            /* Persistent highlight on the currently-selected card */
            .event-card.bb-card-active {
                box-shadow: 0 0 0 3px rgba(255, 193, 7, 0.85);
                border-radius: 0.375rem;
            }
            .event-card:hover { transform: translateY(-1px); transition: transform .1s ease-out; }
            .bb-pill {
                display: inline-block;
                margin-top: .35rem;
                margin-right: .25rem;
                padding: .15rem .55rem;
                border-radius: 999px;
                font-weight: 600;
                text-decoration: none !important;
                font-size: .85em;
            }
            .bb-pill-primary   { background: #0d6efd; color: #fff !important; }
            .bb-pill-primary:hover { background: #0b5ed7; color: #fff !important; }
            .bb-pill-secondary { background: #fff; color: #0d6efd !important; border: 1px solid #0d6efd; }
            .bb-pill-secondary:hover { background: rgba(13, 110, 253, .08); }
        </style>
        <div id="map" style="height: 380px; border-radius: 0.5rem;" class="mb-4"></div>
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
                integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
        <script>
            (function () {
                var points = @Html.Raw(mapJson);
                var map = L.map('map');
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19, attribution: '© OpenStreetMap'
                }).addTo(map);
                var group = L.featureGroup();

                function esc(s) {
                    return String(s).replace(/[&<>"']/g, function (c) {
                        return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
                    });
                }

                // event_key → marker, so card clicks can open the matching marker popup.
                var markersByKey = {};

                // Track the currently-highlighted card so we can move the
                // highlight rather than stacking outlines on every click.
                var activeCard = null;
                function setActiveCard(card) {
                    if (activeCard) activeCard.classList.remove('bb-card-active');
                    activeCard = card;
                    if (card) card.classList.add('bb-card-active');
                }

                points.forEach(function (p) {
                    // Walk: Google Maps walking directions, opens in new tab.
                    // Step-free: handled by our /api/step-free-journey endpoint
                    // which calls TfL's Unified API and renders results in a modal.
                    var walkUrl = 'https://www.google.com/maps/dir/?api=1' +
                                  '&destination=' + encodeURIComponent(p.postcode) +
                                  '&travelmode=walking';

                    var html = '<strong>' + esc(p.name) + '</strong><br>' +
                               esc(p.venue) + '<br>' +
                               esc(p.date) + ' · ' + esc(p.time) +
                               '<br><span style="display:inline-block;width:.6rem;height:.6rem;border-radius:50%;background:' +
                                 esc(p.color) + ';margin-right:.25rem"></span>' +
                               esc(p.category) +
                               '<br><a class="bb-pill bb-pill-primary bb-step-free-btn" href="#" data-postcode="' + esc(p.postcode) + '">Step-free →</a>' +
                               '<a class="bb-pill bb-pill-secondary" href="' + esc(walkUrl) + '" target="_blank" rel="noopener">Walk →</a>';
                    if (p.url) {
                        html += '<br><a href="' + esc(p.url) + '" target="_blank" rel="noopener" style="font-size:.85em">Source</a>';
                    }

                    var marker = L.circleMarker([p.lat, p.lng], {
                        radius: 8,
                        color: '#fff',
                        weight: 2,
                        fillColor: p.color,
                        fillOpacity: 0.9
                    }).bindPopup(html).addTo(group);

                    markersByKey[p.event_key] = marker;

                    // Marker → card: highlight the matching card. No scroll —
                    // leave the page exactly where the user had it.
                    marker.on('click', function () {
                        var card = document.querySelector('[data-event-key="' + cssEscape(p.event_key) + '"]');
                        setActiveCard(card);
                    });
                });

                group.addTo(map);
                map.fitBounds(group.getBounds().pad(0.15));

                // Exposed for the category-filter script: when a category is
                // toggled off, drop its markers from the feature group; toggle
                // back on to re-add. Bounds are intentionally NOT re-fit on
                // filter changes — that'd yank the map around mid-interaction.
                window.bbMapApi = {
                    setExcluded: function (excluded) {
                        points.forEach(function (p) {
                            var marker = markersByKey[p.event_key];
                            if (!marker) return;
                            var hide = excluded.has(p.category_id);
                            if (hide) group.removeLayer(marker);
                            else if (!group.hasLayer(marker)) group.addLayer(marker);
                        });
                    }
                };

                // Card → marker via event delegation on the body. Direct
                // querySelectorAll('.event-card') ran before the cards were
                // parsed into the DOM (script tag appears above them), so
                // attaching listeners up-front captured nothing.
                document.body.addEventListener('click', function (ev) {
                    var card = ev.target.closest('.event-card');
                    if (!card) return;
                    // Don't hijack clicks on actual links inside the card,
                    // or on the Report-mistake button.
                    if (ev.target.closest('a')) return;
                    if (ev.target.closest('.bb-report-btn')) return;
                    setActiveCard(card);
                    var key = card.getAttribute('data-event-key');
                    var marker = markersByKey[key];
                    if (!marker) return;
                    // Just open the popup — keep the user's current map view.
                    // Leaflet's popup auto-pan will nudge the map only if the
                    // popup would otherwise be off-screen; zoom stays put.
                    marker.openPopup();
                });

                // Step-free button inside the marker popup: try browser
                // geolocation; if it's unavailable or denied (common on HTTP
                // origins — most browsers refuse it outside HTTPS/localhost),
                // fall back to a postcode input the user can fill in manually.
                document.body.addEventListener('click', function (ev) {
                    var btn = ev.target.closest('.bb-step-free-btn');
                    if (!btn) return;
                    ev.preventDefault();
                    var postcode = btn.getAttribute('data-postcode');
                    if (!postcode) return;
                    map.closePopup();
                    openJourneyModal('Getting your location…');
                    requestLocation()
                        .then(function (loc) { return fetchAndRender(loc.lat + ',' + loc.lng, postcode); })
                        .catch(function (err) { showOriginFallback(postcode, err.message); });
                });

                function fetchAndRender(from, toPostcode) {
                    setJourneyModal('Finding a step-free route to <strong>' + esc(toPostcode) + '</strong>…');
                    var url = '/api/step-free-journey?from=' + encodeURIComponent(from) +
                              '&to=' + encodeURIComponent(toPostcode);
                    return fetch(url)
                        .then(function (r) {
                            if (!r.ok) throw new Error('Request failed (HTTP ' + r.status + ').');
                            return r.json();
                        })
                        .then(function (data) { setJourneyModal(renderJourney(data, toPostcode)); })
                        .catch(function (err) { setJourneyModal(renderJourneyError(err.message, toPostcode)); });
                }

                function showOriginFallback(toPostcode, reason) {
                    setJourneyModal(
                        '<p class="text-muted small mb-3">' + esc(reason) + '</p>' +
                        '<label class="form-label" for="bb-origin-input">Enter your starting postcode</label>' +
                        '<div class="input-group">' +
                          '<input type="text" id="bb-origin-input" class="form-control" placeholder="e.g. SE1 9PD" autocomplete="postal-code">' +
                          '<button class="btn btn-primary" id="bb-origin-submit" type="button">Plan</button>' +
                        '</div>' +
                        '<p class="form-text mt-2">Step-free routes need to know where you’re starting from. ' +
                        'Browser location isn’t available here — type a postcode and we’ll plan the route via TfL.</p>'
                    );
                    var inp = document.getElementById('bb-origin-input');
                    var sub = document.getElementById('bb-origin-submit');
                    function go() {
                        var v = (inp.value || '').trim();
                        if (!v) { inp.focus(); return; }
                        fetchAndRender(v, toPostcode);
                    }
                    sub.addEventListener('click', go);
                    inp.addEventListener('keydown', function (ev) { if (ev.key === 'Enter') { ev.preventDefault(); go(); } });
                    inp.focus();
                }

                function requestLocation() {
                    return new Promise(function (resolve, reject) {
                        // Cache the user's location for 30 min so repeat clicks
                        // don't re-prompt or re-fix their GPS.
                        var cachedRaw = sessionStorage.getItem('bb-user-location');
                        if (cachedRaw) {
                            try {
                                var c = JSON.parse(cachedRaw);
                                if (Date.now() - c.t < 30 * 60 * 1000) {
                                    resolve({ lat: c.lat, lng: c.lng });
                                    return;
                                }
                            } catch (e) { /* fall through */ }
                        }
                        if (!navigator.geolocation) {
                            reject(new Error('Your browser does not support location access.'));
                            return;
                        }
                        navigator.geolocation.getCurrentPosition(
                            function (pos) {
                                var loc = { lat: pos.coords.latitude, lng: pos.coords.longitude };
                                sessionStorage.setItem('bb-user-location',
                                    JSON.stringify({ lat: loc.lat, lng: loc.lng, t: Date.now() }));
                                resolve(loc);
                            },
                            function (err) {
                                var msg = 'Could not get your location.';
                                if (err && err.code === 1) msg = 'Location permission denied. Enable it in your browser to use step-free routing.';
                                else if (err && err.code === 2) msg = 'Your location could not be determined right now.';
                                else if (err && err.code === 3) msg = 'Location request timed out.';
                                reject(new Error(msg));
                            },
                            { timeout: 10000, maximumAge: 5 * 60 * 1000 }
                        );
                    });
                }

                function openJourneyModal(initialHtml) {
                    setJourneyModal(initialHtml);
                    var el = document.getElementById('bb-journey-modal');
                    if (!el || !window.bootstrap || !bootstrap.Modal) {
                        // Bootstrap JS missing — fall back to alert.
                        alert(el ? el.querySelector('.modal-body').textContent : initialHtml);
                        return;
                    }
                    bootstrap.Modal.getOrCreateInstance(el).show();
                }
                function setJourneyModal(innerHtml) {
                    var body = document.getElementById('bb-journey-modal-body');
                    if (body) body.innerHTML = innerHtml;
                }

                function renderJourney(data, postcode) {
                    var manualLink = 'https://tfl.gov.uk/plan-a-journey/?to=' + encodeURIComponent(postcode);
                    if (!data || data.success === false) {
                        return '<div class="alert alert-warning mb-0">' + esc((data && data.error) || 'No step-free route found.') +
                               '<br><a href="' + esc(manualLink) + '" target="_blank" rel="noopener">Open TfL Journey Planner manually →</a></div>';
                    }
                    var journeys = data.journeys || [];
                    if (journeys.length === 0) {
                        return '<div class="alert alert-warning mb-0">No step-free route found.<br>' +
                               '<a href="' + esc(manualLink) + '" target="_blank" rel="noopener">Open TfL Journey Planner manually →</a></div>';
                    }
                    var html = '<p class="text-muted small mb-3">Step-free route from your location to <strong>' +
                               esc(postcode) + '</strong>.</p>';
                    journeys.forEach(function (j, i) {
                        html += '<div class="card mb-3"><div class="card-body">';
                        html += '<div class="d-flex justify-content-between align-items-baseline mb-2">';
                        html += '<strong>Option ' + (i + 1) + '</strong>';
                        html += '<span class="text-muted small">' + j.durationMinutes + ' min' +
                                (j.fare ? ' · ' + esc(j.fare) : '') + '</span>';
                        html += '</div>';
                        html += '<ul class="list-unstyled mb-0 small">';
                        (j.legs || []).forEach(function (leg) {
                            html += '<li class="mb-1">' + legIcon(leg.mode) + ' ' +
                                    '<strong>' + leg.durationMinutes + ' min</strong> · ';
                            var label = legLineLabel(leg);
                            if (label) html += esc(label) + ' · ';
                            if (leg.mode === 'walking') {
                                html += 'walk' + (leg.toName ? ' to ' + esc(leg.toName) : '');
                            } else {
                                if (leg.fromName) html += esc(leg.fromName);
                                if (leg.toName) html += ' → ' + esc(leg.toName);
                            }
                            html += '</li>';
                        });
                        html += '</ul>';
                        html += '</div></div>';
                    });
                    html += '<div class="text-end"><a href="' + esc(manualLink) +
                            '" target="_blank" rel="noopener" class="small">Open on TfL →</a></div>';
                    return html;
                }

                function renderJourneyError(message, postcode) {
                    var manualLink = 'https://tfl.gov.uk/plan-a-journey/?to=' + encodeURIComponent(postcode);
                    return '<div class="alert alert-warning mb-0">' + esc(message) +
                           '<br><a href="' + esc(manualLink) + '" target="_blank" rel="noopener">Open TfL Journey Planner manually →</a></div>';
                }

                function legLineLabel(leg) {
                    if (!leg.lineName) return null;
                    var label;
                    switch (leg.mode) {
                        case 'bus':
                            label = 'Bus ' + leg.lineName;
                            break;
                        case 'tube':
                        case 'overground':
                        case 'dlr':
                            label = leg.lineName + ' line';
                            break;
                        case 'elizabeth-line':
                            // "Elizabeth" comes back as the line name; avoid "Elizabeth line line".
                            label = /line$/i.test(leg.lineName) ? leg.lineName : leg.lineName + ' line';
                            break;
                        default:
                            label = leg.lineName;
                    }
                    return leg.direction ? label + ' towards ' + leg.direction : label;
                }

                function legIcon(mode) {
                    switch (mode) {
                        case 'walking': return '🚶';
                        case 'tube':    return '🚇';
                        case 'bus':     return '🚌';
                        case 'national-rail':
                        case 'overground':
                        case 'elizabeth-line': return '🚆';
                        case 'dlr':     return '🚊';
                        default:        return '•';
                    }
                }

                // Report-mistake flow: card button stashes the externalKey on the
                // modal's confirm button; clicking confirm POSTs to /api/report-event,
                // shows a brief "Reported" message, then closes the modal.
                document.body.addEventListener('click', function (ev) {
                    var btn = ev.target.closest('.bb-report-btn');
                    if (!btn) return;
                    var key = btn.getAttribute('data-event-key');
                    if (!key) return;
                    var title = btn.getAttribute('data-event-title') || '';
                    var venue = btn.getAttribute('data-event-venue') || '';
                    var confirmBtn = document.getElementById('bb-report-confirm');
                    var msg = document.getElementById('bb-report-modal-message');
                    var fieldSelect = document.getElementById('bb-report-field');
                    if (confirmBtn) {
                        confirmBtn.setAttribute('data-event-key', key);
                        confirmBtn.disabled = true; // re-enabled once user picks a field
                        confirmBtn.textContent = 'Report';
                        confirmBtn.style.display = '';
                    }
                    if (fieldSelect) {
                        fieldSelect.value = ''; // reset to placeholder on every open
                    }
                    if (msg) {
                        // Build the descriptor: "Title at Venue", or fall back to either
                        // alone if one is missing. Both are user-visible content from
                        // scraped sources, so always escape.
                        var descriptor = (title && venue) ? (esc(title) + ' at ' + esc(venue))
                                       : title ? esc(title)
                                       : venue ? esc(venue)
                                       : 'this event';
                        msg.innerHTML = "Tell babybrain.uk that the event details for <strong>" +
                                        descriptor +
                                        "</strong> don't match the source event.";
                    }
                    var modalEl = document.getElementById('bb-report-modal');
                    if (modalEl && window.bootstrap && bootstrap.Modal) {
                        bootstrap.Modal.getOrCreateInstance(modalEl).show();
                    }
                });

                // Gate the Report button on a non-empty dropdown selection.
                document.body.addEventListener('change', function (ev) {
                    if (ev.target && ev.target.id === 'bb-report-field') {
                        var confirmBtn = document.getElementById('bb-report-confirm');
                        if (confirmBtn) confirmBtn.disabled = !ev.target.value;
                    }
                });

                document.body.addEventListener('click', function (ev) {
                    var btn = ev.target.closest('#bb-report-confirm');
                    if (!btn) return;
                    var key = btn.getAttribute('data-event-key');
                    if (!key) return;
                    var fieldSelect = document.getElementById('bb-report-field');
                    var field = fieldSelect ? fieldSelect.value : '';
                    if (!field) return; // dropdown gate failed; do nothing
                    btn.disabled = true;
                    btn.textContent = 'Reporting…';
                    fetch('/api/report-event', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ externalKey: key, reportedField: field })
                    }).then(function (r) {
                        var msg = document.getElementById('bb-report-modal-message');
                        var modalEl = document.getElementById('bb-report-modal');
                        if (!r.ok) {
                            if (msg) msg.innerHTML = '<div class="alert alert-warning mb-0">Sorry, that didn\'t go through. Try again later.</div>';
                            btn.disabled = false;
                            btn.textContent = 'Report';
                            return;
                        }
                        if (msg) msg.innerHTML = '<div class="alert alert-success mb-0">Reported — thanks. We\'ll take a look.</div>';
                        btn.style.display = 'none';
                        if (fieldSelect) fieldSelect.disabled = true;
                        setTimeout(function () {
                            if (modalEl && window.bootstrap && bootstrap.Modal) {
                                bootstrap.Modal.getOrCreateInstance(modalEl).hide();
                            }
                            btn.style.display = '';
                            if (fieldSelect) fieldSelect.disabled = false;
                        }, 1500);
                    }).catch(function () {
                        btn.disabled = false;
                        btn.textContent = 'Report';
                    });
                });

                // CSS.escape polyfill — keys contain colons which CSS would interpret.
                function cssEscape(s) {
                    if (window.CSS && window.CSS.escape) return window.CSS.escape(s);
                    return String(s).replace(/[^a-zA-Z0-9_-]/g, function (c) {
                        return '\\' + c;
                    });
                }
            })();
        </script>
    }

    @foreach (var dayGroup in Model.Results.GroupBy(e => e.Date).OrderBy(g => g.Key))
    {
        var morning = dayGroup.Where(e => e.StartTime.Hour < 12).OrderBy(e => e.StartTime).ToList();
        var afternoon = dayGroup.Where(e => e.StartTime.Hour >= 12).OrderBy(e => e.StartTime).ToList();

        <h2 class="h4 mt-4 mb-3">@dayGroup.Key.ToString("dddd d MMMM")</h2>
        <div class="row g-3">
            <div class="col-md-6">
                <h3 class="h6 text-uppercase text-muted mb-2">Morning</h3>
                @if (morning.Count == 0)
                {
                    <p class="text-muted small fst-italic">Nothing on.</p>
                }
                else
                {
                    @foreach (var ev in morning) { @await Html.PartialAsync("_EventCard", ev) }
                }
            </div>
            <div class="col-md-6">
                <h3 class="h6 text-uppercase text-muted mb-2">Afternoon</h3>
                @if (afternoon.Count == 0)
                {
                    <p class="text-muted small fst-italic">Nothing on.</p>
                }
                else
                {
                    @foreach (var ev in afternoon) { @await Html.PartialAsync("_EventCard", ev) }
                }
            </div>
        </div>
    }
}

<!-- Modal for step-free journey results (populated by JS when the Step-free pill is clicked) -->
<div class="modal fade" id="bb-journey-modal" tabindex="-1" aria-labelledby="bb-journey-modal-title" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bb-journey-modal-title">Step-free journey</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="bb-journey-modal-body">
                <p class="text-muted mb-0">Loading…</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal for "Report mistake" — confirms intent, POSTs to /api/report-event. -->
<div class="modal fade" id="bb-report-modal" tabindex="-1" aria-labelledby="bb-report-modal-title" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bb-report-modal-title">Report a mistake</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="bb-report-modal-message" class="mb-3">
                    Click <strong>Report</strong> to tell babybrain.uk that the event details don't match the source event.
                </p>
                <label for="bb-report-field" class="form-label small mb-1">What's wrong?</label>
                <select id="bb-report-field" class="form-select form-select-sm" required>
                    <option value="" selected disabled>Select what's wrong…</option>
                    <option value="age_range">Age range</option>
                    <option value="time">Time</option>
                    <option value="date">Date</option>
                    <option value="location">Location</option>
                    <option value="cost">Cost</option>
                    <option value="title">Title</option>
                    <option value="not_running">Event isn't running anymore</option>
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="bb-report-confirm" disabled>Report</button>
            </div>
        </div>
    </div>
</div>
