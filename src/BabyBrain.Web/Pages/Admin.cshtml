@page
@model AdminModel
@{
    ViewData["Title"] = "Admin";
}

<h1>Admin</h1>
<p class="text-muted">Trigger a scraper run. This fetches fresh data and upserts into the local database.</p>

<form method="post">
    <button type="submit" class="btn btn-primary">Run all scrapers now</button>
</form>

@if (Model.LastRunSummary is { } summary)
{
    <div class="alert alert-success mt-4">
        <strong>Done.</strong> @summary
    </div>
}
@if (Model.LastRunError is { } err)
{
    <div class="alert alert-danger mt-4">
        <strong>Failed:</strong> @err
    </div>
}

<h2 class="mt-5">Database</h2>
<dl>
    <dt>Total event occurrences</dt><dd>@Model.TotalEvents</dd>
    <dt>Distinct sources</dt><dd>@Model.DistinctSources</dd>
    <dt>Earliest date</dt><dd>@(Model.EarliestDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
    <dt>Latest date</dt><dd>@(Model.LatestDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
</dl>
