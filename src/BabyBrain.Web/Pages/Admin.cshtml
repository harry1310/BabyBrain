@page
@using BabyBrain.Web.Data
@using BabyBrain.Web.Services
@model AdminModel
@{
    ViewData["Title"] = "Admin";
}

<h1>Admin</h1>
<p class="text-muted">Trigger a scraper run. Each source is run independently — one failing source no longer aborts the others.</p>

<form method="post">
    <button type="submit" class="btn btn-primary">Run all scrapers now</button>
</form>

@if (Model.LastResult is { } result)
{
    var alertClass = result.AllSucceeded ? "alert-success" : "alert-warning";
    <div class="alert @alertClass mt-4">
        <strong>@(result.AllSucceeded ? "All scrapers succeeded." : "Some scrapers failed.")</strong>
        @result.TotalRows rows in total · @result.NewGeocodes new postcodes geocoded.
    </div>

    <table class="table table-sm mt-3">
        <thead>
            <tr>
                <th>Source</th>
                <th class="text-center">Status</th>
                <th class="text-end">Rows</th>
                <th>Detail</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var o in result.Outcomes)
        {
            <tr>
                <td><span class="font-monospace small">@o.Source</span></td>
                <td class="text-center">
                    @if (o.Success)
                    {
                        <span class="text-success fs-5" title="Success">✓</span>
                    }
                    else
                    {
                        <span class="text-danger fs-5" title="Failed">✗</span>
                    }
                </td>
                <td class="text-end">@o.Rows</td>
                <td class="small text-muted">@(o.Error ?? "")</td>
            </tr>
        }
        </tbody>
    </table>
}
@if (Model.LastRunError is { } err)
{
    <div class="alert alert-danger mt-4">
        <strong>Run failed at the system level:</strong> @err
    </div>
}

<h2 class="mt-5">Recent runs</h2>
<p class="text-muted small">
    Status icon shows the latest run per source:
    <span class="text-success fw-semibold">✓</span> success ·
    <span class="text-danger fw-semibold">✗</span> failed ·
    <span class="text-warning fw-semibold">⚠</span> succeeded but row count dropped to half or less of the previous successful run.
    Cells show the last 5 runs, most recent first.
</p>

<table class="table table-sm align-middle">
    <thead>
        <tr>
            <th>Source</th>
            <th class="text-center">Status</th>
            <th colspan="5" class="text-center">Recent runs (most recent first)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var h in Model.History)
    {
        var latest = h.Recent.FirstOrDefault();
        <tr>
            <td><span class="font-monospace small">@h.Source</span></td>
            <td class="text-center">
                @if (latest is null)
                {
                    <span class="text-muted" title="No runs yet">—</span>
                }
                else if (latest.Status == ScrapeRun.StatusFailed)
                {
                    <span class="text-danger fs-4" title="Last run failed">✗</span>
                }
                else if (AdminModel.IsDrop(h.Recent, 0))
                {
                    <span class="text-warning fs-4" title="Last run succeeded, but row count is ≤50% of the prior successful run">⚠</span>
                }
                else
                {
                    <span class="text-success fs-4" title="Last run succeeded">✓</span>
                }
            </td>
            @for (var i = 0; i < 5; i++)
            {
                if (i < h.Recent.Count)
                {
                    var run = h.Recent[i];
                    var isFail = run.Status == ScrapeRun.StatusFailed;
                    var isDrop = !isFail && AdminModel.IsDrop(h.Recent, i);
                    var classes = isFail ? "text-danger" : isDrop ? "text-danger fw-semibold" : "";
                    var title = $"{run.StartedAt:yyyy-MM-dd HH:mm} UTC" + (run.Error is null ? "" : $"\n{run.Error}");
                    <td class="text-end @classes" title="@title">
                        @if (isFail)
                        {
                            <text>✗</text>
                        }
                        else
                        {
                            @run.RowsScraped
                        }
                    </td>
                }
                else
                {
                    <td class="text-end text-muted">—</td>
                }
            }
            <td class="text-end">
                <form method="post" asp-page-handler="RunOne" class="d-inline">
                    <input type="hidden" name="source" value="@h.Source" />
                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Re-run just this scraper">Re-run</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

<h2 class="mt-5">Database</h2>
<dl>
    <dt>Total event occurrences</dt><dd>@Model.TotalEvents</dd>
    <dt>Distinct sources</dt><dd>@Model.DistinctSources</dd>
    <dt>Earliest date</dt><dd>@(Model.EarliestDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
    <dt>Latest date</dt><dd>@(Model.LatestDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
</dl>
