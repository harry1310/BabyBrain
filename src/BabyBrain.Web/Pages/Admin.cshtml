@page
@using BabyBrain.Web.Data
@model AdminModel
@{
    ViewData["Title"] = "Admin";
}

<h1>Admin</h1>
<p class="text-muted">
    Trigger a scraper run. Each source runs independently in the background —
    the page polls for completion and updates the status table when scrapes
    finish, so you don't need to keep the tab open.
</p>

<button type="button" id="bb-run-all-btn" class="btn btn-primary">Run all scrapers now</button>
<span id="bb-run-feedback" class="ms-3 text-muted small"></span>

<h2 class="mt-5">Recent runs</h2>
<p class="text-muted small">
    Status icon shows the latest run per source:
    <span class="text-success fw-semibold">✓</span> success ·
    <span class="text-danger fw-semibold">✗</span> failed ·
    <span class="text-secondary fw-semibold">⛔</span> blocked (ScraperAPI credits exhausted — not a fault, no issue raised) ·
    <span class="text-warning fw-semibold">⚠</span> succeeded but row count dropped to half or less of the previous successful run ·
    spinner while a scrape is running.
    Cells show the last 5 runs.
</p>

<partial name="_RecentRunsTable" model="Model" />

<h2 class="mt-5">Fetch cache</h2>
<p class="text-muted small">
    Cached pages for the ScraperAPI-backed sources (listings kept ~2 days, detail
    pages ~7 days) so daily runs don't re-spend credits. A source's
    <strong>Re-run</strong> already bypasses the cache; use <strong>Clear</strong>
    to drop its cached pages so the next scheduled run fetches live.
</p>
<div id="bb-cache-panel" class="small text-muted">Loading cache status…</div>

<h2 class="mt-5">Reported events</h2>
<p class="text-muted small">
    Submitted via the "Report mistake" button on the public event cards.
    Once you've fixed it (or decided no fix is needed), click <strong>Mark fixed</strong>
    to clear the flag. The flag is preserved across scrapes, so you can deal with
    them at your own pace.
</p>

@if (Model.Reported.Count == 0)
{
    <p class="text-muted fst-italic">Nothing reported.</p>
}
else
{
    <table class="table table-sm align-middle" id="bb-reported-table">
        <thead>
            <tr>
                <th>Reported</th>
                <th>What's wrong</th>
                <th>Event</th>
                <th>Source</th>
                <th>When</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var ev in Model.Reported)
        {
            <tr data-reported-row="@ev.ExternalKey">
                <td class="small text-muted">@ev.ReportedAt?.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</td>
                <td><span class="badge text-bg-warning text-dark">@ReportedFields.Label(ev.ReportedField)</span></td>
                <td>
                    <div>@ev.SessionName</div>
                    <div class="small text-muted">@ev.VenueName@(string.IsNullOrEmpty(ev.Postcode) ? "" : $" · {ev.Postcode}")</div>
                </td>
                <td><span class="font-monospace small">@ev.Source</span></td>
                <td class="small">@ev.Date.ToString("yyyy-MM-dd") @ev.StartTime.ToString("HH:mm")</td>
                <td class="text-end">
                    @if (!string.IsNullOrEmpty(ev.SourceUrl))
                    {
                        <a href="@ev.SourceUrl" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary me-1">Open source</a>
                    }
                    <button type="button"
                            class="btn btn-sm btn-outline-primary me-1 bb-raise-issue-btn"
                            data-event-key="@ev.ExternalKey"
                            data-event-title="@ev.SessionName"
                            title="Raise a GitHub issue for this reported event">
                        Raise GH issue
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-outline-success bb-mark-fixed-btn"
                            data-event-key="@ev.ExternalKey"
                            title="Clear the reported flag for this event">
                        Mark fixed
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<h2 class="mt-5">Pending source suggestions</h2>
<p class="text-muted small">
    Submitted via the footer's <strong>Suggest a source</strong> link.
    Click <strong>Mark reviewed</strong> once you've decided whether to add a scraper —
    the row stays in the DB for audit, just disappears from this list.
</p>

@if (Model.PendingSuggestions.Count == 0)
{
    <p class="text-muted fst-italic">Nothing pending.</p>
}
else
{
    <table class="table table-sm align-middle" id="bb-suggestions-table">
        <thead>
            <tr>
                <th>Submitted</th>
                <th>URL</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var s in Model.PendingSuggestions)
        {
            <tr data-suggestion-row="@s.Id">
                <td class="small text-muted">@s.SubmittedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</td>
                <td class="text-break"><a href="@s.Url" target="_blank" rel="noopener">@s.Url</a></td>
                <td class="text-end">
                    <button type="button"
                            class="btn btn-sm btn-outline-success bb-mark-suggestion-btn"
                            data-suggestion-id="@s.Id"
                            title="Clear from the pending list">
                        Mark reviewed
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<h2 class="mt-5">Database</h2>
<dl>
    <dt>Total event occurrences</dt><dd>@Model.TotalEvents</dd>
    <dt>Distinct sources</dt><dd>@Model.DistinctSources</dd>
    <dt>Earliest date</dt><dd>@(Model.EarliestDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
    <dt>Latest date</dt><dd>@(Model.LatestDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
</dl>

<!-- Modal for "Raise GH issue" — reviewer types a description, POSTs to
     /Admin/api/raise-issue, which opens a labelled GitHub issue. -->
<div class="modal fade" id="bb-raise-issue-modal" tabindex="-1" aria-labelledby="bb-raise-issue-title" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bb-raise-issue-title">Raise a GitHub issue</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2 small text-muted" id="bb-raise-issue-event"></p>
                <label for="bb-raise-issue-text" class="form-label">Describe the problem in detail</label>
                <textarea id="bb-raise-issue-text" class="form-control" rows="5"
                          maxlength="4000"
                          placeholder="What's wrong, and anything that would help fix it…"></textarea>
                <div class="form-text">
                    The event's details and source link are attached automatically. The issue is
                    labelled <code>claude-fix</code> and follows the same flow as a failed scrape.
                </div>
                <div id="bb-raise-issue-message" class="mt-2"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="bb-raise-issue-confirm">Raise issue</button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var SPINNER_HTML = '<span class="spinner-border spinner-border-sm text-primary" role="status" title="Scrape running…"><span class="visually-hidden">Running…</span></span>';
    var pollTimer = null;
    var feedbackEl = document.getElementById('bb-run-feedback');
    // Sources the user manually re-ran this session — so we can report each
    // one's outcome when it finishes (even a 1-second failure/blocked run).
    var pendingReruns = new Set();

    document.getElementById('bb-run-all-btn').addEventListener('click', function () {
        feedbackEl.textContent = 'Queuing…';
        fetch('/Admin/api/rerun-all', { method: 'POST' })
            .then(parseJson)
            .then(function (data) {
                if (data.queued > 0) {
                    feedbackEl.textContent = 'Queued ' + data.queued + ' source' + (data.queued === 1 ? '' : 's') + '. Background scrape running — the status table will update when done.';
                    setAllSpinners();
                    startPolling();
                } else {
                    feedbackEl.textContent = data.message || 'Nothing queued.';
                }
            })
            .catch(function (err) {
                feedbackEl.textContent = 'Failed to queue: ' + err.message;
            });
    });

    document.body.addEventListener('click', function (ev) {
        var btn = ev.target.closest('.bb-rerun-btn');
        if (!btn) return;
        ev.preventDefault();
        var source = btn.getAttribute('data-source');
        if (!source) return;
        pendingReruns.add(source);
        btn.disabled = true;
        setSpinner(source);
        fetch('/Admin/api/rerun-source', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ source: source })
        }).then(parseJson)
          .then(function (data) {
              // Whether newly queued or already running, poll until done.
              startPolling();
          })
          .catch(function (err) {
              btn.disabled = false;
              feedbackEl.textContent = 'Failed to queue ' + source + ': ' + err.message;
              // Revert the spinner so the user can retry.
              window.location.reload();
          });
    });

    // Mark a reported event as fixed: POST to /Admin/api/mark-fixed, then
    // remove the row. If the table empties, replace it with the "nothing
    // reported" placeholder paragraph.
    document.body.addEventListener('click', function (ev) {
        var btn = ev.target.closest('.bb-mark-fixed-btn');
        if (!btn) return;
        ev.preventDefault();
        var key = btn.getAttribute('data-event-key');
        if (!key) return;
        btn.disabled = true;
        btn.textContent = 'Clearing…';
        fetch('/Admin/api/mark-fixed', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ externalKey: key })
        }).then(parseJson)
          .then(function () {
              var row = document.querySelector('[data-reported-row="' + cssEscape(key) + '"]');
              if (row) row.remove();
              var table = document.getElementById('bb-reported-table');
              if (table && !table.querySelector('tbody tr')) {
                  var p = document.createElement('p');
                  p.className = 'text-muted fst-italic';
                  p.textContent = 'Nothing reported.';
                  table.parentNode.replaceChild(p, table);
              }
          })
          .catch(function (err) {
              btn.disabled = false;
              btn.textContent = 'Mark fixed';
              alert('Failed to clear: ' + err.message);
          });
    });

    // Mark a source suggestion as reviewed: clear the row in place.
    document.body.addEventListener('click', function (ev) {
        var btn = ev.target.closest('.bb-mark-suggestion-btn');
        if (!btn) return;
        ev.preventDefault();
        var id = btn.getAttribute('data-suggestion-id');
        if (!id) return;
        btn.disabled = true;
        btn.textContent = 'Clearing…';
        fetch('/Admin/api/mark-suggestion-reviewed', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(id, 10) })
        }).then(parseJson)
          .then(function () {
              var row = document.querySelector('[data-suggestion-row="' + id + '"]');
              if (row) row.remove();
              var table = document.getElementById('bb-suggestions-table');
              if (table && !table.querySelector('tbody tr')) {
                  var p = document.createElement('p');
                  p.className = 'text-muted fst-italic';
                  p.textContent = 'Nothing pending.';
                  table.parentNode.replaceChild(p, table);
              }
          })
          .catch(function (err) {
              btn.disabled = false;
              btn.textContent = 'Mark reviewed';
              alert('Failed to clear: ' + err.message);
          });
    });

    // After a manual Re-run finishes, read each source's freshly-rendered status
    // cell and surface the outcome — so even a 1-second failed/blocked run gives
    // clear confirmation (✓ / ✗ / ⛔) instead of looking like nothing happened.
    function reportRerunOutcomes() {
        var msgs = [];
        pendingReruns.forEach(function (source) {
            var cell = document.querySelector('[data-status-cell="' + cssEscape(source) + '"]');
            var span = cell ? cell.querySelector('span') : null;
            var symbol = span ? span.textContent.trim() : '?';
            var detail = span ? (span.getAttribute('title') || '') : 'no status recorded';
            msgs.push(source + ': ' + symbol + ' ' + detail);
            if (cell) {
                cell.style.transition = 'background-color 0.4s';
                cell.style.backgroundColor = '#fff3cd';
                setTimeout(function () { cell.style.backgroundColor = ''; }, 2500);
            }
        });
        pendingReruns.clear();
        if (msgs.length) feedbackEl.textContent = 'Finished — ' + msgs.join('  |  ');
    }

    function setSpinner(source) {
        var cell = document.querySelector('[data-status-cell="' + cssEscape(source) + '"]');
        if (cell) cell.innerHTML = SPINNER_HTML;
    }

    function setAllSpinners() {
        document.querySelectorAll('[data-status-cell]').forEach(function (cell) {
            cell.innerHTML = SPINNER_HTML;
        });
        document.querySelectorAll('.bb-rerun-btn').forEach(function (b) { b.disabled = true; });
    }

    function startPolling() {
        if (pollTimer) return;
        pollTimer = setInterval(pollStatus, 2000);
        pollStatus(); // immediate first check
    }

    function pollStatus() {
        fetch('/Admin/api/source-status')
            .then(parseJson)
            .then(function (data) {
                var running = data.running || [];
                if (running.length === 0) {
                    clearInterval(pollTimer);
                    pollTimer = null;
                    refreshHistoryTable();
                }
            })
            .catch(function () { /* transient — keep polling */ });
    }

    // Swap just the "Recent runs" table for a freshly-rendered fragment so
    // the new ScrapeRun rows appear without a full-page reload. Event
    // handlers are delegated on document.body, so the replaced markup stays
    // wired up. Falls back to a full reload if the fragment fetch fails.
    function refreshHistoryTable() {
        fetch('/Admin?handler=History')
            .then(function (r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.text();
            })
            .then(function (html) {
                var table = document.getElementById('bb-history-table');
                if (table) {
                    table.outerHTML = html;
                    renderCachePanel();
                    if (pendingReruns.size > 0) reportRerunOutcomes();
                    else feedbackEl.textContent = 'Scrape finished.';
                } else {
                    window.location.reload();
                }
            })
            .catch(function () { window.location.reload(); });
    }

    // Raise a GitHub issue for a reported event: open the modal and stash the
    // event key on the confirm button.
    document.body.addEventListener('click', function (ev) {
        var btn = ev.target.closest('.bb-raise-issue-btn');
        if (!btn) return;
        ev.preventDefault();
        var key = btn.getAttribute('data-event-key');
        if (!key) return;
        var title = btn.getAttribute('data-event-title') || '';
        var confirmBtn = document.getElementById('bb-raise-issue-confirm');
        var textEl = document.getElementById('bb-raise-issue-text');
        var eventEl = document.getElementById('bb-raise-issue-event');
        var msgEl = document.getElementById('bb-raise-issue-message');
        confirmBtn.setAttribute('data-event-key', key);
        confirmBtn.disabled = false;
        confirmBtn.textContent = 'Raise issue';
        confirmBtn.style.display = '';
        textEl.value = '';
        textEl.disabled = false;
        eventEl.textContent = title ? ('Event: ' + title) : '';
        msgEl.innerHTML = '';
        var modalEl = document.getElementById('bb-raise-issue-modal');
        if (modalEl && window.bootstrap && bootstrap.Modal) {
            bootstrap.Modal.getOrCreateInstance(modalEl).show();
        }
        setTimeout(function () { textEl.focus(); }, 200);
    });

    // Confirm: POST the description to /Admin/api/raise-issue.
    document.body.addEventListener('click', function (ev) {
        var btn = ev.target.closest('#bb-raise-issue-confirm');
        if (!btn) return;
        var key = btn.getAttribute('data-event-key');
        if (!key) return;
        var textEl = document.getElementById('bb-raise-issue-text');
        var msgEl = document.getElementById('bb-raise-issue-message');
        var description = (textEl.value || '').trim();
        if (!description) {
            msgEl.innerHTML = '<div class="alert alert-warning mb-0 py-2 small">Please describe the problem first.</div>';
            textEl.focus();
            return;
        }
        btn.disabled = true;
        btn.textContent = 'Raising…';
        fetch('/Admin/api/raise-issue', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ externalKey: key, description: description })
        }).then(function (r) {
            return r.json().then(function (data) { return { ok: r.ok, data: data }; });
        }).then(function (res) {
            if (!res.ok) {
                var err = document.createElement('div');
                err.className = 'alert alert-danger mb-0 py-2 small';
                err.textContent = (res.data && res.data.error) || 'Failed to raise the issue.';
                msgEl.innerHTML = '';
                msgEl.appendChild(err);
                btn.disabled = false;
                btn.textContent = 'Raise issue';
                return;
            }
            var box = document.createElement('div');
            box.className = 'alert alert-success mb-0 py-2 small';
            box.appendChild(document.createTextNode('Issue raised: '));
            if (res.data.url) {
                var a = document.createElement('a');
                a.href = res.data.url;
                a.target = '_blank';
                a.rel = 'noopener';
                a.textContent = '#' + res.data.number;
                box.appendChild(a);
            } else {
                box.appendChild(document.createTextNode('#' + res.data.number));
            }
            msgEl.innerHTML = '';
            msgEl.appendChild(box);
            btn.style.display = 'none';
            textEl.disabled = true;
        }).catch(function () {
            msgEl.innerHTML = '<div class="alert alert-danger mb-0 py-2 small">Network error — try again.</div>';
            btn.disabled = false;
            btn.textContent = 'Raise issue';
        });
    });

    function parseJson(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
    }

    function cssEscape(s) {
        if (window.CSS && window.CSS.escape) return window.CSS.escape(s);
        return String(s).replace(/[^a-zA-Z0-9_-]/g, function (c) { return '\\' + c; });
    }

    // Fetch-cache panel: per source, split listing vs detail with page counts and
    // when each kind next goes cold (so you can spot a source about to refetch live
    // — keep the laptop up before then to avoid ScraperAPI credits). Clear per source.
    function renderCachePanel() {
        var panel = document.getElementById('bb-cache-panel');
        if (!panel) return;
        var now = Date.now();
        function fmtExpiry(iso) {
            if (!iso) return { txt: 'unknown', cls: 'text-muted' };
            var diff = new Date(iso).getTime() - now;
            var past = diff < 0;
            var h = Math.floor(Math.abs(diff) / 3600000), d = Math.floor(h / 24);
            h = h % 24;
            var span = d > 0 ? (d + 'd ' + h + 'h') : (h + 'h');
            if (past) return { txt: 'cold (' + span + ' ago)', cls: 'text-danger fw-semibold' };
            return { txt: 'in ' + span, cls: (d < 1 ? 'fw-semibold' : '') };
        }
        fetch('/Admin/api/cache-status')
            .then(parseJson)
            .then(function (stats) {
                if (!stats || stats.length === 0) { panel.textContent = 'Cache is empty.'; return; }
                var body = '';
                stats.forEach(function (s) {
                    var kinds = (s.kinds && s.kinds.length) ? s.kinds
                        : [{ kind: 'unknown', entries: s.entries, nextExpiry: null, lastExpiry: null }];
                    kinds.forEach(function (k, i) {
                        var exp = fmtExpiry(k.nextExpiry);
                        var title = (k.lastExpiry && k.lastExpiry !== k.nextExpiry)
                            ? ' title="last ' + k.kind + ' page expires ' + new Date(k.lastExpiry).toLocaleString() + '"'
                            : '';
                        body += '<tr>';
                        if (i === 0)
                            body += '<td class="font-monospace small" rowspan="' + kinds.length + '">' + s.source + '</td>';
                        body += '<td>' + k.kind + '</td>' +
                                '<td class="text-end">' + k.entries + '</td>' +
                                '<td class="text-end ' + exp.cls + '"' + title + '>' + exp.txt + '</td>';
                        if (i === 0)
                            body += '<td class="text-end" rowspan="' + kinds.length + '">' +
                                    '<button type="button" class="btn btn-sm btn-outline-secondary bb-clear-cache-btn" data-source="' + s.source + '">Clear</button></td>';
                        body += '</tr>';
                    });
                });
                panel.innerHTML =
                    '<table class="table table-sm align-middle" style="max-width:640px">' +
                    '<thead><tr><th>Source</th><th>Type</th><th class="text-end">Pages</th><th class="text-end">Next expiry</th><th></th></tr></thead>' +
                    '<tbody>' + body + '</tbody></table>';
            })
            .catch(function () { panel.textContent = 'Could not load cache status.'; });
    }

    document.body.addEventListener('click', function (ev) {
        var btn = ev.target.closest('.bb-clear-cache-btn');
        if (!btn) return;
        ev.preventDefault();
        var source = btn.getAttribute('data-source');
        if (!source) return;
        btn.disabled = true;
        btn.textContent = 'Clearing…';
        fetch('/Admin/api/clear-cache', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ source: source })
        }).then(parseJson).then(function () { renderCachePanel(); })
          .catch(function () { btn.disabled = false; btn.textContent = 'Clear'; });
    });

    // On load — populate the fetch-cache panel, and if the server marked any
    // sources as already running (e.g. the user reloaded mid-scrape), pick up
    // polling so the page refreshes when they finish.
    renderCachePanel();
    @if (Model.RunningSources.Count > 0)
    {
        <text>startPolling();</text>
    }
})();
</script>
